---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  title: string;
  subtitle?: string;
  image?: ImageMetadata;
  imageAlt?: string;
  dark?: boolean;
  /** Taller hero, lighter mid-overlay so the photo pops (use on home) */
  dramatic?: boolean;
}
const { title, subtitle, image, imageAlt = '', dark = false, dramatic = false } = Astro.props;
const minH = dramatic ? 'min-h-[56vh] sm:min-h-[68vh]' : 'min-h-[44vh] sm:min-h-[52vh]';
const overlay = dark
  ? 'background: linear-gradient(to top, rgb(11 18 32 / 0.94) 0%, rgb(17 24 39 / 0.55) 48%, rgb(15 47 74 / 0.28) 100%)'
  : dramatic
    ? 'background: linear-gradient(to top, rgb(10 31 51 / 0.93) 0%, rgb(15 47 74 / 0.45) 42%, rgb(0 0 0 / 0.12) 70%, transparent 100%)'
    : 'background: linear-gradient(to top, rgb(10 31 51 / 0.92) 0%, rgb(30 106 158 / 0.45) 45%, rgb(15 23 42 / 0.25) 100%)';
---

<section class={`relative w-full overflow-hidden text-white ${minH} ${dark ? 'bg-night-900' : 'bg-park-900'}`}>
  {
    image ? (
      <>
        <Image
          src={image}
          alt={imageAlt}
          widths={[640, 960, 1280, 1600, 1920]}
          sizes="100vw"
          class={`absolute inset-0 h-full w-full object-cover ${dramatic ? 'object-[center_45%] scale-[1.02]' : 'object-center'}`}
          loading="eager"
          fetchpriority="high"
        />
        <div class="absolute inset-0" style={overlay} aria-hidden="true" />
      </>
    ) : (
      <div class="absolute inset-0 bg-gradient-to-br from-park-800 via-park-900 to-night-900" aria-hidden="true" />
    )
  }
  <div class={`page-container relative flex flex-col justify-end pb-12 pt-24 sm:pb-16 sm:pt-28 ${minH}`}>
    <div class="mb-4 h-1 w-14 rounded-full bg-glow shadow-[0_0_12px_rgba(167,243,208,0.6)]" aria-hidden="true" />
    <h1 class={`font-bold tracking-tight text-white drop-shadow-md ${dramatic ? 'text-4xl sm:text-5xl md:text-6xl lg:text-7xl' : 'text-4xl sm:text-5xl md:text-6xl'}`}>
      {title}
    </h1>
    {subtitle && (
      <p class={`mt-4 max-w-2xl text-white/95 drop-shadow-sm ${dramatic ? 'text-lg sm:text-xl md:text-2xl' : 'text-lg sm:text-xl'}`}>
        {subtitle}
      </p>
    )}
    <slot />
  </div>
</section>
