---
import type { Trail } from '../data/trails';

interface Props {
  trail: Trail;
}

const { trail } = Astro.props;

const effortClass =
  trail.effort === 'easy'
    ? 'bg-emerald-100 text-emerald-900 dark:bg-emerald-950 dark:text-emerald-200'
    : trail.effort === 'moderate'
      ? 'bg-amber-100 text-amber-900 dark:bg-amber-950 dark:text-amber-200'
      : 'bg-rose-100 text-rose-900 dark:bg-rose-950 dark:text-rose-200';
---

<a href={`/trails/${trail.slug}/`} class="card group block p-5 transition hover:border-park-400 hover:shadow-md dark:hover:border-park-500">
  <div class="flex flex-wrap items-start justify-between gap-2">
    <h3 class="text-lg font-bold text-park-900 group-hover:text-park-700 dark:text-park-50 dark:group-hover:text-park-200">
      {trail.shortName}
    </h3>
    <span class:list={['rounded-full px-2.5 py-0.5 text-xs font-semibold capitalize', effortClass]}>{trail.effort}</span>
  </div>
  <p class="mt-2 line-clamp-3 text-sm text-mist-700 dark:text-park-200/85">{trail.summary}</p>
  <dl class="mt-4 grid grid-cols-2 gap-2 text-xs text-park-800 dark:text-park-200 sm:grid-cols-3">
    <div>
      <dt class="font-semibold text-mist-700 dark:text-park-400">Grade</dt>
      <dd>{trail.gradeLabel}</dd>
    </div>
    <div>
      <dt class="font-semibold text-mist-700 dark:text-park-400">Time</dt>
      <dd>{trail.time}</dd>
    </div>
    <div class="col-span-2 sm:col-span-1">
      <dt class="font-semibold text-mist-700 dark:text-park-400">Distance</dt>
      <dd>{trail.distance}</dd>
    </div>
  </dl>
  <p class="mt-3 text-xs font-medium text-park-600 dark:text-park-300">View guide →</p>
</a>
