---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  src: ImageMetadata;
  alt: string;
  /** Shown under the image — should match or echo the section heading */
  caption?: string;
  class?: string;
  imgClass?: string;
  loading?: 'lazy' | 'eager';
  priority?: boolean;
}

const {
  src,
  alt,
  caption,
  class: className = '',
  imgClass = 'max-h-80 w-full object-cover',
  loading = 'lazy',
  priority = false,
} = Astro.props;
---

<figure class:list={['overflow-hidden rounded-2xl border border-mist-200 bg-white shadow-sm dark:border-park-700 dark:bg-park-900/40', className]}>
  <Image
    src={src}
    alt={alt}
    widths={[640, 960, 1280]}
    sizes="(max-width: 768px) 100vw, 960px"
    class={imgClass}
    loading={loading}
    fetchpriority={priority ? 'high' : undefined}
  />
  {
    caption && (
      <figcaption class="border-t border-mist-200 px-4 py-2.5 text-sm font-medium text-park-800 dark:border-park-700 dark:text-park-100">
        {caption}
      </figcaption>
    )
  }
</figure>
