---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { PHOTO_CREDIT } from '../data/photoCredit';

interface Item {
  src: ImageMetadata;
  alt: string;
  caption?: string;
}
interface Props {
  items: Item[];
  columns?: 2 | 3;
}
const { items, columns = 3 } = Astro.props;
const gridClass = columns === 2 ? 'sm:grid-cols-2' : 'sm:grid-cols-2 lg:grid-cols-3';

/**
 * Split caption into title + credit (RNP wildlife style).
 * Prefer “Title · © Ian Piggott · ianpiggott.com” — first segment = title, rest = credit.
 */
function splitCaption(caption?: string): { title: string; credit: string } {
  if (!caption) return { title: '', credit: '' };
  const parts = caption.split(/\s*·\s*/).map((p) => p.trim()).filter(Boolean);
  if (parts.length >= 2) {
    if (parts[0].startsWith('©')) {
      return { title: '', credit: parts.join(' · ') };
    }
    return { title: parts[0], credit: parts.slice(1).join(' · ') };
  }
  return { title: caption.trim(), credit: '' };
}

function isIanCredit(credit: string): boolean {
  return /ian\s*piggott|ianpiggott\.com/i.test(credit);
}
---

<div class={`grid gap-5 ${gridClass}`} data-lightbox-gallery>
  {
    items.map((item, index) => {
      const { title, credit } = splitCaption(item.caption);
      const captionTitle = title || item.alt;
      return (
        <figure class="overflow-hidden rounded-2xl border border-mist-200/80 bg-white shadow-sm transition duration-300 hover:shadow-md dark:border-park-800 dark:bg-park-900/40 dark:hover:border-park-600">
          <button
            type="button"
            class="group relative block w-full cursor-zoom-in overflow-hidden text-left"
            data-lightbox-open
            data-index={index}
            aria-label={`View larger: ${item.alt}`}
          >
            <Image
              src={item.src}
              alt={item.alt}
              widths={[400, 640, 960]}
              sizes={columns === 2 ? '(max-width:640px) 100vw, 50vw' : '(max-width:640px) 100vw, (max-width:1024px) 50vw, 33vw'}
              class="h-56 w-full object-cover transition duration-300 group-hover:scale-[1.03] group-hover:brightness-[0.97] sm:h-64"
              loading="lazy"
            />
            <span
              class="pointer-events-none absolute bottom-3 right-3 rounded-full bg-black/55 px-2.5 py-1 text-[0.65rem] font-semibold uppercase tracking-wide text-white/95 opacity-90 sm:text-xs"
              aria-hidden="true"
            >
              Tap to enlarge
            </span>
          </button>
          {(item.caption || item.alt) && (
            <figcaption class="px-3 py-2.5 sm:px-4 sm:py-3">
              {captionTitle ? (
                <span class="block text-sm font-medium leading-snug text-park-900 dark:text-park-50">{captionTitle}</span>
              ) : null}
              {credit ? (
                <span class="mt-1 block text-[0.7rem] leading-snug text-mist-700 opacity-90 dark:text-park-300">
                  {isIanCredit(credit) ? (
                    <>
                      © {PHOTO_CREDIT.name}
                      {' · '}
                      <a
                        href={PHOTO_CREDIT.url}
                        class="font-medium text-park-700 underline-offset-2 hover:underline dark:text-glow"
                        target="_blank"
                        rel="noopener noreferrer"
                      >
                        ianpiggott.com
                      </a>
                    </>
                  ) : (
                    credit
                  )}
                </span>
              ) : null}
            </figcaption>
          )}
        </figure>
      );
    })
  }
</div>

{/* Hidden sources for lightbox */}
<div class="hidden" data-lightbox-sources aria-hidden="true">
  {
    items.map((item) => (
      <div data-full-src={item.src.src} data-alt={item.alt} data-caption={item.caption || ''} />
    ))
  }
</div>

<dialog
  id="snp-lightbox"
  class="fixed inset-0 z-[100] m-0 h-full max-h-none w-full max-w-none border-0 bg-black/90 p-0 text-white backdrop:bg-black/80 open:flex open:items-center open:justify-center"
>
  <div class="relative flex max-h-[100dvh] w-full max-w-5xl flex-col items-center justify-center px-4 py-12">
    <button
      type="button"
      class="absolute right-4 top-4 z-10 rounded-full bg-white/10 px-3 py-2 text-sm font-semibold hover:bg-white/20"
      data-lightbox-close
      aria-label="Close"
    >
      Close
    </button>
    <button
      type="button"
      class="absolute left-2 top-1/2 z-10 -translate-y-1/2 rounded-full bg-white/10 px-3 py-4 text-lg hover:bg-white/20 sm:left-4"
      data-lightbox-prev
      aria-label="Previous"
    >
      ‹
    </button>
    <button
      type="button"
      class="absolute right-2 top-1/2 z-10 -translate-y-1/2 rounded-full bg-white/10 px-3 py-4 text-lg hover:bg-white/20 sm:right-4"
      data-lightbox-next
      aria-label="Next"
    >
      ›
    </button>
    <img id="snp-lightbox-img" src="" alt="" class="max-h-[75dvh] w-auto max-w-full rounded-lg object-contain" />
    <p id="snp-lightbox-cap" class="mt-4 max-w-2xl text-center text-sm text-white/80"></p>
  </div>
</dialog>

<script>
  function initLightbox() {
    const dialog = document.getElementById('snp-lightbox') as HTMLDialogElement | null;
    if (!dialog) return;
    const sources = Array.from(document.querySelectorAll('[data-lightbox-sources] > [data-full-src]'));
    if (!sources.length) return;

    let index = 0;
    const img = document.getElementById('snp-lightbox-img') as HTMLImageElement | null;
    const cap = document.getElementById('snp-lightbox-cap');

    function show(i: number) {
      index = (i + sources.length) % sources.length;
      const el = sources[index] as HTMLElement;
      if (img) {
        img.src = el.dataset.fullSrc || '';
        img.alt = el.dataset.alt || '';
      }
      if (cap) cap.textContent = el.dataset.caption || el.dataset.alt || '';
    }

    document.querySelectorAll('[data-lightbox-open]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const i = Number((btn as HTMLElement).dataset.index || 0);
        show(i);
        dialog?.showModal();
      });
    });

    dialog.querySelector('[data-lightbox-close]')?.addEventListener('click', () => dialog.close());
    dialog.querySelector('[data-lightbox-prev]')?.addEventListener('click', () => show(index - 1));
    dialog.querySelector('[data-lightbox-next]')?.addEventListener('click', () => show(index + 1));
    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) dialog.close();
    });
    document.addEventListener('keydown', (e) => {
      if (!dialog.open) return;
      if (e.key === 'ArrowLeft') show(index - 1);
      if (e.key === 'ArrowRight') show(index + 1);
    });
  }

  initLightbox();
  document.addEventListener('astro:page-load', initLightbox);
</script>
