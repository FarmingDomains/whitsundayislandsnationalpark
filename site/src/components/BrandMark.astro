---
/**
 * Whitsunday Islands brand mark — unique to this site (not Uluru/Cradle).
 * Reads as: lagoon water + archipelago islands + Whitehaven silica sand + tropical sun.
 */
interface Props {
  class?: string;
  title?: string;
}

const { class: className = 'h-9 w-9 sm:h-10 sm:w-10', title = 'Whitsunday Islands National Park guide' } = Astro.props;
---

<svg
  class={className}
  viewBox="0 0 32 32"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  role="img"
  aria-label={title}
>
  <title>{title}</title>
  <!-- Deep lagoon tile -->
  <rect width="32" height="32" rx="8" fill="#0c3d45" class="opacity-95 group-hover:opacity-100" />

  <!-- Soft sky wash -->
  <path d="M0 0h32v14H0z" fill="#11515a" opacity=".45" />

  <!-- Tropical sun -->
  <circle cx="24.5" cy="8" r="2.4" fill="#e8d4a8" opacity=".95" />
  <circle cx="24.5" cy="8" r="3.4" stroke="#e8d4a8" stroke-width="0.6" opacity=".35" />

  <!-- Distant island chain (archipelago) -->
  <path
    d="M5 16.5c1.2-1.8 2.4-2.6 3.6-2.6 1.1 0 1.7.9 2.4 1.6.6-.9 1.5-1.8 2.8-1.8 1.4 0 2.2 1.2 3 2.1.7-1.1 1.8-2.2 3.4-2.2 1.6 0 2.6 1.3 3.4 2.4.5-.6 1.2-1.1 2.2-1.1 1.3 0 2.4 1.2 3.2 2.3"
    stroke="#5eead4"
    stroke-width="1.15"
    stroke-linecap="round"
    stroke-linejoin="round"
    fill="none"
    opacity=".9"
  />

  <!-- Main island mass + hoop-pine silhouette -->
  <path
    d="M9 19.2c1.8-2.4 3.2-3.5 5-3.5 1.5 0 2.3 1 3.1 2 .9-1.4 2.2-2.6 4.1-2.6 2.2 0 3.6 1.8 4.8 3.5"
    fill="#0f6570"
    opacity=".95"
  />
  <!-- Hoop pine (simple vertical canopy) -->
  <path d="M15.2 15.2 L15.2 18.8" stroke="#6dd4db" stroke-width="1" stroke-linecap="round" />
  <path d="M13.6 16.4 L15.2 14.6 L16.8 16.4" stroke="#6dd4db" stroke-width="1" stroke-linejoin="round" fill="none" />
  <path d="M14 17.2 L15.2 15.8 L16.4 17.2" stroke="#6dd4db" stroke-width="0.9" stroke-linejoin="round" fill="none" />

  <!-- Turquoise water band -->
  <path
    d="M3 22.2c2.2-.6 4.2-1.8 6.5-1.8s3.5 1.4 5.5 1.4 3.2-1.5 5.8-1.5 4.2.9 6.2 1.5"
    stroke="#38bdc8"
    stroke-width="1.45"
    stroke-linecap="round"
    fill="none"
  />
  <path
    d="M3 24.1c2.4-.5 4.6-1.4 6.8-1.4 2.4 0 3.6 1.1 5.6 1.1s3.4-1.2 6-1.2c2.2 0 4.2.7 5.6 1.2"
    stroke="#5eead4"
    stroke-width="1.1"
    stroke-linecap="round"
    fill="none"
    opacity=".85"
  />

  <!-- Whitehaven silica sand beach (foreground curve) -->
  <path
    d="M2 27.2c3.5-1.4 7-2.2 10.5-2.2 4 0 7.2 1.2 10.8 2.1 2.2.5 4.2.8 6.7.9v2H2v-2.8z"
    fill="#f3f0e6"
    opacity=".95"
  />
  <path
    d="M3 26.4c3.2-1 6.5-1.6 9.8-1.6 3.6 0 6.8.9 10.2 1.7"
    stroke="#e8d4a8"
    stroke-width="0.7"
    stroke-linecap="round"
    fill="none"
    opacity=".7"
  />
</svg>
