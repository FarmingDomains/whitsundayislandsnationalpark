---
interface Props {
  title?: string;
  items: string[];
}
const { title = "Don’t get this wrong", items } = Astro.props;
---

<aside class="my-8 rounded-2xl border border-warn-200 bg-warn-50 px-5 py-5 sm:px-6" aria-label={title}>
  <p class="text-xs font-bold uppercase tracking-[0.16em] text-warn-800">{title}</p>
  <ul class="mt-3 list-disc space-y-2 pl-5 text-sm text-warn-800 sm:text-base">
    {items.map((item) => <li>{item}</li>)}
  </ul>
</aside>
