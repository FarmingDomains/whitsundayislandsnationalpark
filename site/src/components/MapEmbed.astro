---
/**
 * Privacy-friendly Google Maps embed (no API key).
 * Uses the public maps embed endpoint + open-in-Maps / directions links.
 */
interface Props {
  /** Search / place query for the embed */
  query: string;
  title?: string;
  /** Zoom 1–20, higher = closer */
  zoom?: number;
  /** Optional height class */
  heightClass?: string;
  caption?: string;
}
const {
  query,
  title = 'Map',
  zoom = 12,
  heightClass = 'h-[min(420px,55vh)] min-h-[280px]',
  caption,
} = Astro.props;

const encoded = encodeURIComponent(query);
const embedSrc = `https://maps.google.com/maps?q=${encoded}&z=${zoom}&hl=en&output=embed`;
const openUrl = `https://www.google.com/maps/search/?api=1&query=${encoded}`;
const directionsUrl = `https://www.google.com/maps/dir/?api=1&destination=${encoded}`;
---

<figure class="my-6 overflow-hidden rounded-2xl border border-mist-200 bg-white shadow-sm dark:border-park-700 dark:bg-park-900/40">
  <div class={`relative w-full ${heightClass} bg-mist-100 dark:bg-park-900`}>
    <iframe
      title={title}
      src={embedSrc}
      class="absolute inset-0 h-full w-full border-0"
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
      allowfullscreen
    />
  </div>
  <figcaption class="flex flex-col gap-3 border-t border-mist-200 px-4 py-3 sm:flex-row sm:items-center sm:justify-between dark:border-park-700">
    <p class="text-sm text-mist-700 dark:text-park-200/85">
      {caption || 'Interactive map — pin may be approximate. Confirm boat landings, track status and marine conditions before you go (island sites are not drive-up).'}
    </p>
    <div class="flex flex-wrap gap-2 shrink-0">
      <a
        href={openUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center rounded-lg border border-park-200 bg-park-50 px-3 py-1.5 text-xs font-semibold text-park-900 hover:bg-park-100 dark:border-park-600 dark:bg-park-800 dark:text-park-50 dark:hover:bg-park-700"
      >
        Open in Google Maps
      </a>
      <a
        href={directionsUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center rounded-lg bg-park-600 px-3 py-1.5 text-xs font-semibold text-white hover:bg-park-700"
      >
        Get directions
      </a>
    </div>
  </figcaption>
</figure>
