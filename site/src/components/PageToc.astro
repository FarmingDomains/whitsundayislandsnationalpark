---
interface Item {
  href: string;
  label: string;
}
interface Props {
  items: Item[];
  title?: string;
}
const { items, title = 'On this page' } = Astro.props;
---

<nav
  class="mb-10 rounded-2xl border border-mist-200 bg-white/90 p-5 shadow-sm dark:border-park-700 dark:bg-park-900/50"
  aria-label={title}
>
  <p class="text-xs font-bold uppercase tracking-[0.16em] text-park-700 dark:text-park-300">{title}</p>
  <ol class="mt-3 flex flex-col gap-1.5 sm:flex-row sm:flex-wrap sm:gap-x-4 sm:gap-y-1">
    {
      items.map((item, i) => (
        <li>
          <a
            href={item.href}
            class="inline-flex items-center gap-2 rounded-lg px-1 py-1 text-sm font-medium text-park-800 underline-offset-2 hover:text-park-600 hover:underline dark:text-park-100 dark:hover:text-glow"
          >
            <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-park-100 text-[10px] font-bold text-park-800 dark:bg-park-800 dark:text-park-100">
              {i + 1}
            </span>
            {item.label}
          </a>
        </li>
      ))
    }
  </ol>
</nav>
