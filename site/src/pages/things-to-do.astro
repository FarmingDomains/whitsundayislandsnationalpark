---
import Layout from '../layouts/Layout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import TrailCard from '../components/TrailCard.astro';
import MonetisationPanel from '../components/MonetisationPanel.astro';
import OfficialResources from '../components/OfficialResources.astro';
import AdSense from '../components/AdSense.astro';
import { trails } from '../data/trails';
import { official } from '../data/seo';

const crumbs = [
  { name: 'Home', href: '/' },
  { name: 'Things to do' },
];

const easy = trails.filter((t) => t.effort === 'easy');
const moderate = trails.filter((t) => t.effort === 'moderate');
const hard = trails.filter((t) => t.effort === 'hard');

const beyondWalks = [
  {
    title: 'Whitehaven Beach day trips',
    body: 'The high-volume path from Airlie Beach / Shute Harbour: crewed day tour, fixed window, shared icon beach. Read whether Hill Inlet lookout is included. Day-trip honesty applies in peak season.',
    href: '/trails/whitehaven-beach/',
    cta: 'Whitehaven guide',
  },
  {
    title: 'Overnight island camping',
    body: 'QPWS permit + boat transfer (or private vessel), water packed in, stove only, tag displayed. Classic Whitehaven nights or quieter beaches such as Chance Bay / Dugong — solitude costs logistics.',
    href: '/park/camping-beaches/',
    cta: 'Camping beaches hub',
  },
  {
    title: 'Fringing reef snorkel',
    body: 'Conditions-dependent sites (e.g. Black Island, Butterfly Bay, Blue Pearl Bay, Border Island on commercial itineraries). Stinger suits typically Nov–May. Never stand on coral; trust skipper site changes.',
    href: '/trails/fringing-reef-snorkel/',
    cta: 'Snorkel guide',
  },
  {
    title: 'Multi-day sailing / island-hopping',
    body: 'Crewed multi-day sail or qualified bareboat for archipelago immersion beyond one beach. Higher cost and weather sensitivity; still need a flexible Whitehaven attempt day.',
    href: '/itineraries/multi-day-sailing/',
    cta: 'Sailing itinerary',
  },
  {
    title: 'Ngaro cultural sites',
    body: 'Public interpretive tracks only — stay on path, no restricted rock-art photography, no invented sacred stories. Reef etiquette is part of Sea Country respect.',
    href: '/trails/ngaro-cultural-site/',
    cta: 'Cultural site guide',
  },
  {
    title: 'Scenic flights (Heart Reef / aerial Whitehaven)',
    body: 'Premium context layer, not a substitute for ground-level beach time. Useful buffer-day or “already did the boat” option. Ethical operators and marine rules still apply.',
    href: '/tours/',
    cta: 'Tours & flights',
  },
];
---

<Layout
  title="Things to do"
  fullTitle="Things to Do at Whitsunday Islands · Whitehaven, Hill Inlet, Snorkel & Camping"
  description="Whitsunday Islands things to do: Whitehaven Beach, Hill Inlet lookout, short island walks, fringing reef snorkel, camping beaches and Ngaro cultural sites — filtered by boat access, tides and fitness."
  breadcrumbs={crumbs}
>
  <div class="page-container py-8 sm:py-12">
    <Breadcrumbs items={crumbs} />
    <h1 class="mt-4 text-3xl font-bold sm:text-4xl">Things to do</h1>
    <p class="mt-3 max-w-3xl text-mist-700 dark:text-park-200">
      Everything in Whitsunday Islands National Park is <strong class="text-park-900 dark:text-park-50">boat-access gated</strong> — there is no public road to Whitehaven or Hill Inlet.
      Start with how you will reach the islands (day tour, camping transfer, private vessel or multi-day sail), then match beaches, lookouts and snorkel stops to weather, tides, fitness and muster times.
    </p>
    <p class="mt-3 max-w-3xl text-sm text-mist-700 dark:text-park-300">
      Official status:{' '}
      <a class="font-semibold text-park-700 underline-offset-2 hover:underline dark:text-park-300" href={official.park} target="_blank" rel="noopener noreferrer">Queensland Parks — Whitsunday Islands</a>
      {' · '}
      <a class="font-semibold text-park-700 underline-offset-2 hover:underline dark:text-park-300" href={official.hillInlet} target="_blank" rel="noopener noreferrer">Hill Inlet lookout track</a>
      {' · '}
      <a class="font-semibold text-park-700 underline-offset-2 hover:underline dark:text-park-300" href={official.alerts} target="_blank" rel="noopener noreferrer">Park alerts</a>.
      This site does not show live closures.
    </p>

    <aside class="mt-8 grid gap-4 rounded-2xl border border-park-200 bg-park-50/80 p-5 dark:border-park-700 dark:bg-park-900/40 sm:grid-cols-3 sm:p-6">
      <div>
        <p class="text-xs font-bold uppercase tracking-[0.14em] text-park-600 dark:text-park-300">First-timers</p>
        <p class="mt-1 text-sm text-mist-700 dark:text-park-300">
          Crewed day tour: <a class="font-semibold text-park-700 underline-offset-2 hover:underline dark:text-park-200" href="/trails/whitehaven-beach/">Whitehaven</a>
          {' ± '}
          <a class="font-semibold text-park-700 underline-offset-2 hover:underline dark:text-park-200" href="/trails/hill-inlet-lookout/">Hill Inlet</a>
          {' · '}
          <a class="font-semibold text-park-700 underline-offset-2 hover:underline dark:text-park-200" href="/itineraries/whitehaven-hill-inlet-day/">day itinerary</a>
        </p>
      </div>
      <div>
        <p class="text-xs font-bold uppercase tracking-[0.14em] text-park-600 dark:text-park-300">Photographers</p>
        <p class="mt-1 text-sm text-mist-700 dark:text-park-300">
          Tide-aware lookout plan — mid-to-high often helps the swirl, never guaranteed.{' '}
          <a class="font-semibold text-park-700 underline-offset-2 hover:underline dark:text-park-200" href="/itineraries/photography-tide-hill-inlet/">Photography itinerary</a>
        </p>
      </div>
      <div>
        <p class="text-xs font-bold uppercase tracking-[0.14em] text-park-600 dark:text-park-300">Campers</p>
        <p class="mt-1 text-sm text-mist-700 dark:text-park-300">
          Permit + water in + stove only.{' '}
          <a class="font-semibold text-park-700 underline-offset-2 hover:underline dark:text-park-200" href="/itineraries/overnight-whitehaven-camping/">Overnight camping plan</a>
        </p>
      </div>
    </aside>

    <section class="mt-12">
      <h2 class="text-xl font-bold">Easy / high reward</h2>
      <p class="mt-2 max-w-2xl text-sm text-mist-700 dark:text-park-300">
        Beach time, short circuits and cultural interpretive walks — still boat-gated; still need sun, water and muster discipline.
      </p>
      <div class="mt-4 grid gap-4 md:grid-cols-2">
        {easy.map((t) => <TrailCard trail={t} />)}
      </div>
    </section>

    <section class="mt-12">
      <h2 class="text-xl font-bold">Moderate (lookouts &amp; links)</h2>
      <p class="mt-2 max-w-2xl text-sm text-mist-700 dark:text-park-300">
        Hill Inlet steps, camping beach links and effort that feels harder in tropical heat than the brochure distance suggests.
      </p>
      <div class="mt-4 grid gap-4 md:grid-cols-2">
        {moderate.map((t) => <TrailCard trail={t} />)}
      </div>
    </section>

    <section class="mt-12">
      <h2 class="text-xl font-bold">Harder / multi-day</h2>
      <p class="mt-2 max-w-2xl text-sm text-mist-700 dark:text-park-300">
        Ngaro Track–class immersion — limited numbers, seasonal windows, official booking only. Not a day-tour upgrade.
      </p>
      <div class="mt-4 grid gap-4 md:grid-cols-2">
        {hard.map((t) => <TrailCard trail={t} />)}
      </div>
    </section>

    <section class="mt-14">
      <h2 class="text-2xl font-bold">Beyond the walk cards</h2>
      <p class="mt-2 max-w-3xl text-sm text-mist-700 dark:text-park-300">
        The trail cards above cover walks and activity guides. These are the other high-intent ways people actually use the park — each links to deeper planning on this site.
      </p>
      <div class="mt-6 grid gap-4 md:grid-cols-2">
        {
          beyondWalks.map((item) => (
            <a
              href={item.href}
              class="card group flex flex-col p-5 transition hover:border-park-400 hover:shadow-md dark:hover:border-park-500"
            >
              <h3 class="text-lg font-bold text-park-900 group-hover:text-park-700 dark:text-park-50 dark:group-hover:text-glow">
                {item.title}
              </h3>
              <p class="mt-2 flex-1 text-sm leading-relaxed text-mist-700 dark:text-park-300">{item.body}</p>
              <span class="mt-4 text-sm font-semibold text-park-700 dark:text-park-300">
                {item.cta} →
              </span>
            </a>
          ))
        }
      </div>
      <p class="mt-6 text-sm text-mist-700 dark:text-park-300">
        Full-day structures:{' '}
        <a class="font-semibold text-park-700 underline-offset-2 hover:underline dark:text-park-200" href="/itineraries/">itineraries</a>
        {' · '}
        Bookable products:{' '}
        <a class="font-semibold text-park-700 underline-offset-2 hover:underline dark:text-park-200" href="/tours/">tours</a>
        {' · '}
        Logistics:{' '}
        <a class="font-semibold text-park-700 underline-offset-2 hover:underline dark:text-park-200" href="/visit/">plan your visit</a>
        {' · '}
        Access filter:{' '}
        <a class="font-semibold text-park-700 underline-offset-2 hover:underline dark:text-park-200" href="/park/boat-access-airlie/">boat access hub</a>.
      </p>
    </section>

    <AdSense unit="inContent" />

    <div class="mt-12">
      <MonetisationPanel primaryStay="airlieBeach" />
    </div>

    <div class="mt-10">
      <OfficialResources />
    </div>
  </div>
</Layout>
