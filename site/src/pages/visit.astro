---
import Layout from '../layouts/Layout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import WeatherWidget from '../components/WeatherWidget.astro';
import LeadCapture from '../components/LeadCapture.astro';
import MonetisationPanel from '../components/MonetisationPanel.astro';
import OfficialResources from '../components/OfficialResources.astro';
import AdSense from '../components/AdSense.astro';
import FaqList from '../components/FaqList.astro';
import { official } from '../data/seo';
import { contentMeta } from '../data/contentMeta';
import { faqJsonLd } from '../data/seo';

const faqs = [
  {
    question: 'Do I need a camping permit for a Whitehaven day trip?',
    answer:
      'No. Commercial day tours do not use national park camping permits. Overnight camping on Whitsunday Islands National Park beaches requires a Queensland Parks booking and permit, with fees and a displayed tag. This site never sells permits.',
  },
  {
    question: 'How much is camping?',
    answer:
      'Fees are set by Queensland Parks and change — commonly cited around $7.75 per adult per night or a family rate (children under 5 free under published policy). Always re-check live prices on parks.qld.gov.au camping bookings before you book.',
  },
  {
    question: 'Can I drive to Whitehaven Beach?',
    answer:
      'No. Whitehaven Beach and Hill Inlet are boat-access only. Base in Airlie Beach (or a resort island), then use a day tour, camping transfer, private vessel or multi-day charter.',
  },
  {
    question: 'What is the best time to visit?',
    answer:
      'Dry season (roughly May–October) is generally preferred for more stable weather and whale season opportunities, but it is also peak demand. Wet season brings higher humidity, storm/cyclone risk and stinger awareness if swimming. Build a weather buffer day if Whitehaven is non-negotiable.',
  },
  {
    question: 'When is stinger season?',
    answer:
      'Marine stinger risk is typically highest from November to May in tropical Queensland. Follow Queensland Health and operator guidance; full-body suits are common for snorkelling in season. Always re-check current advice.',
  },
];

const crumbs = [
  { name: 'Home', href: '/' },
  { name: 'Plan your visit' },
];
---

<Layout
  title="Plan your visit"
  fullTitle="Plan Your Visit · Whitsunday Islands National Park"
  description="Plan Whitsunday Islands National Park: boat access from Airlie Beach, camping permits, Hill Inlet tides, stinger season, packing and seasons. Always verify with Queensland Parks (QPWS)."
  breadcrumbs={crumbs}
  jsonLd={faqJsonLd(faqs)}
>
  <div class="page-container py-8 sm:py-12">
    <Breadcrumbs items={crumbs} />
    <h1 class="mt-4 text-3xl font-bold sm:text-4xl">Plan your visit to Whitsunday Islands</h1>
    <p class="mt-3 max-w-3xl text-mist-700 dark:text-park-200">
      Use this page for boat logistics, camping realism, packing and safety. For live fees, track status and alerts, always use{' '}
      <a class="font-semibold text-park-700 underline-offset-2 hover:underline dark:text-park-300" href={official.park} target="_blank" rel="noopener noreferrer">Queensland Parks — Whitsunday Islands</a>.
      Content reviewed {contentMeta.siteReviewed}.
    </p>

    <div class="mt-8">
      <WeatherWidget />
    </div>

    <div class="prose-park mt-10 max-w-3xl space-y-10">
      <section>
        <h2>Getting there</h2>
        <p>
          Fly into <strong>Proserpine / Whitsunday Coast (PPP)</strong> or <strong>Hamilton Island (HTI)</strong>, then base for most visitors at{' '}
          <strong>Airlie Beach</strong> (mainland hub for day tours and camping transfers). <strong>Shute Harbour</strong> is a key departure node for many vessels.
        </p>
        <p>
          There is <strong>no road to Whitehaven Beach or Hill Inlet</strong>. Access is by commercial day tour, camping transfer / water taxi, private vessel, bareboat or multi-day sail charter.
          Confirm operator check-in times and weather cancellation policies before you lock non-refundable flights tight against a single boat day.
        </p>
      </section>

      <section>
        <h2>Boat-access decision hierarchy</h2>
        <ul>
          <li><strong>Day tour</strong> — dominant high-volume path; convenience over solitude</li>
          <li><strong>Camping transfer</strong> — overnight immersion; requires QPWS permit + full self-sufficiency</li>
          <li><strong>Private vessel / bareboat / multi-day sail</strong> — freedom path; skills and GBRMPA rules required</li>
        </ul>
        <p>
          Deep dive: <a href="/park/boat-access-airlie/">boat access &amp; Airlie Beach hub</a>.
        </p>
      </section>

      <section>
        <h2>Camping permits (overnight only)</h2>
        <p>
          Overnight camping on national park beaches requires a booking through the{' '}
          <a href={official.bookings} target="_blank" rel="noopener noreferrer">Queensland Parks Booking Service</a>.
          Fees apply; a tag with your booking number must be displayed. Day tours do not use camping permits.
        </p>
        <p>
          Plan water carefully — <strong>no reliable fresh water on most sites</strong> (commonly plan 5 L+ per person per day; verify official advice).
          <strong>No campfires</strong> — stove only. Carry out all waste. Run pest-free / biosecurity checks on boats and gear.
          <strong>We never take commission on camping permits.</strong>
        </p>
        <p>
          Official camping page:{' '}
          <a href={official.camping} target="_blank" rel="noopener noreferrer">parks.qld.gov.au — Whitsunday camping</a>.
        </p>
      </section>

      <section>
        <h2>Ngaro culture &amp; respectful visiting</h2>
        <p>
          We acknowledge the <strong>Ngaro people</strong> as Traditional Owners of the Whitsunday islands and surrounding Sea Country.
          Visit public cultural sites only, stay on marked tracks, do not touch rock art, and do not invent restricted stories.
          Prefer authorised guides and operators that respect cultural and marine park protocols.
        </p>
      </section>

      <section id="marine-safety">
        <h2>Marine safety, stingers, tides &amp; weather</h2>
        <ul>
          <li>Wind and swell cancel boats — build a buffer day if Whitehaven is non-negotiable.</li>
          <li>Stinger season is typically <strong>November–May</strong> — full-body suit or avoid swimming; follow operator rules.</li>
          <li>Hill Inlet swirl photography is <strong>tide-dependent</strong> — check BOM tides, not only social media.</li>
          <li>Many landings feel easier mid-to-high tide; trust skippers when they change plans.</li>
          <li>Reef etiquette: no standing on coral, no taking shells/coral, follow GBRMPA zoning if you skipper yourself.</li>
          <li>Recreational drones need proper authorisation — do not assume you can fly.</li>
          <li>Check <a href={official.alerts} target="_blank" rel="noopener noreferrer">park alerts</a> the morning you go.</li>
        </ul>
        <p>
          More detail: <a href="/park/marine-safety-seasons/">marine safety &amp; seasons</a>.
        </p>
      </section>

      <section>
        <h2>Best time / seasons</h2>
        <p>
          <strong>Dry season (roughly May–October)</strong> is generally preferred for weather stability and whale opportunities — and peak demand for day tours and Airlie beds.
          <strong>Wet season</strong> brings humidity, heavy rain risk and cyclone awareness. There is no zero-risk week; choose flexible bookings that match your tolerance.
        </p>
      </section>

      <section>
        <h2>Packing list (tropical boat + island)</h2>
        <ul>
          <li>Dry bag + waterproof phone pouch</li>
          <li>UPF shirt, wide-brim hat with cord, polarised sunglasses, reef-safe high-SPF sunscreen</li>
          <li>Closed-toe shoes for Hill Inlet lookout and rocky landings</li>
          <li>Stinger suit / lycra if swimming or snorkelling in season (typically Nov–May)</li>
          <li>Water + snacks for day tours (even when lunch is included, pack backup hydration)</li>
          <li>Campers: collapsible water storage, stove + fuel (no fires), headlamp, waste bags, first aid, comms plan</li>
          <li>Seasickness plan if you are prone</li>
          <li>Offline booking QR / screenshots for tours and camping permits</li>
        </ul>
        <p>
          See <a href="/gear/">gear essentials</a> for Amazon AU product searches (affiliate disclosure applies).
        </p>
      </section>

      <section>
        <h2>Where to stay</h2>
        <p>
          <strong>Airlie Beach</strong> is the practical mainland hub (backpackers to resorts and holiday parks) for day tours and camping transfers.
          Cannonvale extends the bed pool. <strong>Hamilton Island</strong> is the resort-island alternative — still confirm how you reach Whitehaven from your resort base.
          Peak dry-season inventory sells out; book early.
        </p>
        <p>
          Details: <a href="/stay/">where to stay</a>.
        </p>
      </section>
    </div>

    <div class="mt-12 max-w-3xl">
      <h2 id="visit-faq-heading" class="text-xl font-bold">FAQs</h2>
      <div class="mt-4 not-prose">
        <FaqList items={faqs} labelledBy="visit-faq-heading" />
      </div>
    </div>

    <AdSense unit="inContent" />

    <div class="mt-12">
      <LeadCapture mode="tips" downloadPath="/downloads/whitsunday-practical-planner.html" />
    </div>

    <div class="mt-12">
      <MonetisationPanel
        primaryStay="airlieBeach"
        title="Book an Airlie Beach base, then add tours & kit"
        description="Stay links first — camping permits remain official-only. Peak season: book accommodation and boats early."
      />
    </div>

    <div class="mt-10">
      <OfficialResources />
    </div>
  </div>
</Layout>
