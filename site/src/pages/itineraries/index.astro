---
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import LeadCapture from '../../components/LeadCapture.astro';
import MonetisationPanel from '../../components/MonetisationPanel.astro';
import { itineraries } from '../../data/itineraries';

const crumbs = [
  { name: 'Home', href: '/' },
  { name: 'Itineraries' },
];
---

<Layout
  title="Itineraries"
  fullTitle="Whitsunday Islands Itineraries · Day Plans & Multi-Day"
  description="Printable Whitsunday Islands itineraries: essential first visit, Whitehaven Beach early start, multi-day Airlie Beach, Alice day-trip honesty, family plans and photography days."
  breadcrumbs={crumbs}
>
  <div class="page-container py-8 sm:py-12">
    <Breadcrumbs items={crumbs} />
    <h1 class="mt-4 text-3xl font-bold sm:text-4xl">Itineraries</h1>
    <p class="mt-3 max-w-3xl text-mist-700 dark:text-park-200">
      These plans are built for real Great Barrier Reef World Heritage logistics — camping permit, Ngaro cultural sites first, tropical heat and energy — not fantasy "Whitehaven Beach and Valley before lunch" checklists.
      Pick the plan that matches your group, then open it for a full timeline, packing notes and what to skip.
    </p>
    <p class="mt-3 max-w-3xl text-sm text-mist-700 dark:text-park-300">
      Every itinerary still defers to <strong class="text-park-900 dark:text-park-100">Queensland Parks (QPWS)</strong> for track status, temperature closures and alerts.
      Print any plan from the page, or grab the free Practical Planner.
    </p>

    <div class="mt-8 grid gap-4 md:grid-cols-2">
      {
        itineraries.map((it) => (
          <a href={`/itineraries/${it.slug}/`} class="card block p-5 transition hover:border-park-400">
            <p class="text-xs font-bold uppercase tracking-wide text-park-600 dark:text-park-300">{it.duration}</p>
            <h2 class="mt-1 text-lg font-bold text-park-900 dark:text-park-50">{it.name}</h2>
            <p class="mt-2 text-sm text-mist-700 dark:text-park-300">{it.summary}</p>
            <p class="mt-3 text-xs font-semibold text-park-600 dark:text-park-300">Open plan →</p>
          </a>
        ))
      }
    </div>

    <div class="mt-12">
      <MonetisationPanel
        primaryStay="airlieBeach"
        title="Stays & tours after you pick a plan"
        description="Book a Airlie Beach base, browse guided experiences, or grab desert kit — after you pick an itinerary that fits heat and culture."
      />
    </div>

    <div class="mt-10">
      <LeadCapture downloadPath="/downloads/whitsunday-practical-planner.html" />
    </div>
  </div>
</Layout>
