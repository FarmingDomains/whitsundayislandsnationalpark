---
import Layout from '../layouts/Layout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import MonetisationPanel from '../components/MonetisationPanel.astro';
import OfficialResources from '../components/OfficialResources.astro';
import { gearLinks, externalRel, affiliateDisclosureShort } from '../data/affiliates';

const crumbs = [
  { name: 'Home', href: '/' },
  { name: 'Gear essentials' },
];

const gear = gearLinks();
---

<Layout
  title="Gear essentials"
  fullTitle="Whitsunday Boat & Island Gear Essentials"
  description="Desert packing for Whitsunday Islands: UPF clothing, hydration packs, electrolytes, sun hats, headlamps and more. Amazon AU links with affiliate disclosure."
  breadcrumbs={crumbs}
>
  <div class="page-container py-8 sm:py-12">
    <Breadcrumbs items={crumbs} />
    <h1 class="mt-4 text-3xl font-bold sm:text-4xl">Gear essentials for desert walks</h1>
    <p class="mt-3 max-w-3xl text-mist-700 dark:text-park-200">
      The Whitsundays are not a city beach day day-walk mild. Prioritise sun defence, hydration and early-start logistics.
      Product links may earn Amazon Associates commissions (AU tag). {affiliateDisclosureShort}
    </p>

    <ul class="mt-8 grid gap-4 sm:grid-cols-2">
      {
        gear.map((item) => (
          <li class="card p-5">
            <a
              href={item.href}
              target="_blank"
              rel={externalRel(item.sponsored)}
              class="text-lg font-bold text-park-800 underline-offset-2 hover:underline dark:text-park-100"
            >
              {item.label}
            </a>
            <p class="mt-2 text-sm text-mist-700 dark:text-park-300">{item.note}</p>
          </li>
        ))
      }
    </ul>

    <div class="prose-park mt-10 max-w-3xl">
      <h2>Packing mindset</h2>
      <p>
        Carry more water than feels reasonable for a short coastal loop. Wear UPF clothing instead of relying on sunscreen alone.
        Pack a headlamp for sunrise. After rain, flies can be intense — a head net earns its place.
        Always re-check official safety guidance before you walk.
      </p>
      <p>
        Full trip logistics live on the <a href="/visit/">plan your visit</a> page. Free printable checklist:{' '}
        <a href="/downloads/whitsunday-practical-planner.html">Whitsunday Practical Planner</a>.
      </p>
    </div>

    <div class="mt-12">
      <MonetisationPanel primaryStay="airlieBeach" showGear={false} title="Stays & tours for your kit list trip" />
    </div>

    <div class="mt-10">
      <OfficialResources />
    </div>
  </div>
</Layout>
