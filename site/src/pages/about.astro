---
import Layout from '../layouts/Layout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { official, sisterParks } from '../data/seo';

const crumbs = [
  { name: 'Home', href: '/' },
  { name: 'About' },
];
---

<Layout
  title="About this guide"
  fullTitle="About This Guide · Whitsunday Islands National Park"
  description="About the unofficial Whitsunday Islands National Park guide by Farming Domains — independent planning advice, not Queensland Parks (QPWS), GBRMPA or Ngaro Traditional Owners."
  breadcrumbs={crumbs}
>
  <div class="page-container py-8 sm:py-12">
    <Breadcrumbs items={crumbs} />
    <h1 class="mt-4 text-3xl font-bold sm:text-4xl">About this guide</h1>
    <div class="prose-park mt-6 max-w-3xl">
      <p>
        <strong class="text-park-900 dark:text-park-50">whitsundayislandsnationalpark.com.au</strong> is an independent, unofficial visitor guide.
        We help people plan boat-access decisions, Whitehaven Beach and Hill Inlet days, camping self-sufficiency, snorkel realism and Airlie Beach logistics
        for Whitsunday Islands National Park, Queensland.
      </p>
      <p>
        We are <strong>not</strong> Queensland Parks (QPWS), the Department of the Environment, Tourism, Science and Innovation, GBRMPA,
        Ngaro Traditional Owners, commercial tour operators, Tourism Whitsundays, or any other government or commercial attraction operator.
      </p>
      <p>
        We acknowledge the Ngaro people as Traditional Owners of the Whitsunday islands and surrounding Sea Country.
        This guide does not retell restricted sacred stories. Use public interpretive material, authorised cultural products and official park communications only.
      </p>
      <p>
        Always verify camping fees, track status, marine conditions and safety on the{' '}
        <a class="font-semibold text-park-700 underline-offset-2 hover:underline dark:text-park-300" href={official.park} target="_blank" rel="noopener noreferrer">official Queensland Parks pages</a>
        {' '}and{' '}
        <a class="font-semibold text-park-700 underline-offset-2 hover:underline dark:text-park-300" href={official.gbrmpaWhitsundays} target="_blank" rel="noopener noreferrer">GBRMPA Whitsundays</a>
        {' '}before you travel.
      </p>
      <h2>Farming Domains portfolio</h2>
      <p>This site is part of a family of unofficial Australian national park guides:</p>
      <ul>
        {
          sisterParks.map((p) => (
            <li>
              <a href={p.href} target="_blank" rel="noopener noreferrer">
                {p.label}
              </a>
              {p.note ? ` — ${p.note}` : ''}
            </li>
          ))
        }
      </ul>
      <p>
        Questions about this website (not park emergencies): <a href="/contact/">contact form</a>.
        For emergencies call <strong>000</strong>. For official park help use Queensland Parks channels.
      </p>
    </div>
  </div>
</Layout>
