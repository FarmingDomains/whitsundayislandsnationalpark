---
/**
 * Homepage information architecture:
 * 1. Hero — Whitehaven silica + CTAs
 * 2. Trust strip — unofficial + verify with QPWS
 * 3. Feature chips
 * 4. Boat-access decision hierarchy
 * 5. Icon pair + activity decision tree
 * 6. Essential walks spotlight
 * 7. Marine / stinger / tide realism
 * 8. Itineraries
 * 9. Lead magnet
 * 10. Monetisation → Official resources
 */
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import LeadCapture from '../components/LeadCapture.astro';
import MonetisationPanel from '../components/MonetisationPanel.astro';
import OfficialResources from '../components/OfficialResources.astro';
import AdSense from '../components/AdSense.astro';
import TrailCard from '../components/TrailCard.astro';
import WeatherWidget from '../components/WeatherWidget.astro';
import { official } from '../data/seo';
import { getTrail } from '../data/trails';
import { itineraries } from '../data/itineraries';
import { contentMeta } from '../data/contentMeta';
import { siteImages } from '../data/pageImages';

const featuredTrails = [
  getTrail('hill-inlet-lookout')!,
  getTrail('whitehaven-beach')!,
  getTrail('fringing-reef-snorkel')!,
].filter(Boolean);

const featuredItineraries = itineraries.filter((it) =>
  ['whitehaven-hill-inlet-day', 'overnight-whitehaven-camping', 'airlie-base-day-trips'].includes(it.slug),
);

const featureChips = [
  'Great Barrier Reef World Heritage',
  'Ngaro Traditional Owners',
  'Whitehaven Beach',
  'Hill Inlet lookout',
  'Boat access only',
  'Camping permits',
  'Stinger season realism',
  'Airlie Beach hub',
];

const accessSteps = [
  {
    n: '1',
    title: 'Choose your access path',
    detail:
      'Day tour (volume path), camping transfer (immersion), or private / multi-day sail (freedom). Match budget, solitude and skills.',
  },
  {
    n: '2',
    title: 'Base in Airlie Beach',
    detail:
      'Practical mainland hub for tours and transfers. Book peak dry-season beds early. Hamilton Island is the resort alternative.',
  },
  {
    n: '3',
    title: 'Icon pair when you can',
    detail:
      'Whitehaven Beach + Hill Inlet lookout (~1.3 km return, ~40 min). Confirm inclusions and tide windows.',
  },
  {
    n: '4',
    title: 'Marine realism always',
    detail:
      'Weather cancels boats. Stingers typically Nov–May. No reliable fresh water on most camps — pack it in. No campfires.',
  },
];

const decisionTree = [
  {
    href: '/park/whitehaven-hill-inlet/',
    label: 'Essential icons',
    title: 'Whitehaven + Hill Inlet',
    meta: 'Day tour or camp · tide-aware photos',
    blurb: 'The global pair. Boat access only — plan the logistics first.',
  },
  {
    href: '/park/camping-beaches/',
    label: 'Overnight',
    title: 'Island camping hierarchy',
    meta: 'Permit + transfer · self-sufficient',
    blurb: 'Whitehaven classic or secluded beaches — water in, waste out.',
  },
  {
    href: '/park/boat-access-airlie/',
    label: 'How to get there',
    title: 'Boat access decision tree',
    meta: 'Tour · transfer · private · sail',
    blurb: 'Filters by budget, time, solitude and group size.',
  },
  {
    href: '/park/snorkel-reef/',
    label: 'In the water',
    title: 'Snorkel & fringing reefs',
    meta: 'Conditions-dependent · stinger suits',
    blurb: 'Black Island, Butterfly Bay, Blue Pearl Bay and more — when the weather allows.',
  },
];
---

<Layout
  title="Whitsunday Islands National Park"
  fullTitle="Whitsunday Islands National Park: Whitehaven Beach, Hill Inlet & Boat Access Guide"
  description="Unofficial practical guide to Whitsunday Islands National Park — Whitehaven Beach & Hill Inlet, boat-access decisions, camping permits, stinger season, tides and Airlie Beach logistics. Always verify with Queensland Parks."
>
  <PageHero
    title="Whitsunday Islands"
    subtitle="Unofficial operator’s manual for Whitehaven silica sand, Hill Inlet tides, boat-access honesty and self-sufficient camping — so you arrive ready, not weather-struck."
    image={siteImages.homeHero.src}
    imageAlt={siteImages.homeHero.alt}
    dramatic
  >
    <div class="mt-8 flex flex-wrap gap-3">
      <a href="#boat-access" class="btn-primary">Boat access decisions</a>
      <a href="/trails/hill-inlet-lookout/" class="btn-secondary-on-dark">Hill Inlet lookout</a>
      <a
        href={official.park}
        class="btn-secondary-on-dark"
        target="_blank"
        rel="noopener noreferrer"
      >
        Official Queensland Parks
      </a>
    </div>
    <p class="mt-5 max-w-xl text-sm text-white/85">
      Independent guide · Not affiliated with QPWS, GBRMPA or Ngaro Traditional Owners · Content reviewed {contentMeta.siteReviewed}
    </p>
  </PageHero>

  <div class="page-container py-10 sm:py-14">
    <div class="rounded-2xl border border-park-200 bg-park-50/90 p-4 dark:border-park-700 dark:bg-park-900/50 sm:flex sm:items-start sm:justify-between sm:gap-6 sm:p-5">
      <p class="text-sm text-park-900 dark:text-park-100">
        <strong>How to use this site:</strong> we explain boat logistics, beach hierarchy and marine realism in plain English.
        <strong class="font-semibold"> Queensland Parks sets camping permits, fees, track status and park rules. GBRMPA sets marine park rules.</strong>
        Always confirm on the{' '}
        <a class="font-semibold underline-offset-2 hover:underline" href={official.park} target="_blank" rel="noopener noreferrer">official park site</a>,
        {' '}
        <a class="font-semibold underline-offset-2 hover:underline" href={official.camping} target="_blank" rel="noopener noreferrer">camping page</a>
        {' '}and{' '}
        <a class="font-semibold underline-offset-2 hover:underline" href={official.alerts} target="_blank" rel="noopener noreferrer">park alerts</a>
        {' '}before you travel. This site does not show live closures.
      </p>
    </div>

    <ul class="mt-6 flex flex-wrap gap-2" role="list" aria-label="Park character">
      {
        featureChips.map((chip) => (
          <li class="rounded-full border border-park-200/90 bg-white px-3 py-1.5 text-xs font-semibold text-park-800 dark:border-park-600 dark:bg-park-900 dark:text-park-100">
            {chip}
          </li>
        ))
      }
    </ul>

    <aside class="mt-8 grid gap-4 rounded-2xl border border-mist-200 bg-white p-5 dark:border-park-700 dark:bg-park-900/40 sm:grid-cols-3 sm:p-6">
      <div>
        <p class="text-xs font-bold uppercase tracking-[0.14em] text-park-600 dark:text-park-300">Icon pair</p>
        <p class="mt-1 font-bold text-park-900 dark:text-park-50">Whitehaven + Hill Inlet</p>
        <p class="mt-1 text-sm text-mist-700 dark:text-park-300">Silica beach + tidal swirl lookout — boat access only.</p>
      </div>
      <div>
        <p class="text-xs font-bold uppercase tracking-[0.14em] text-park-600 dark:text-park-300">Mainland hub</p>
        <p class="mt-1 font-bold text-park-900 dark:text-park-50">Airlie Beach</p>
        <p class="mt-1 text-sm text-mist-700 dark:text-park-300">Day tours, transfers and peak-season beds. Book early.</p>
      </div>
      <div>
        <p class="text-xs font-bold uppercase tracking-[0.14em] text-park-600 dark:text-park-300">Hard rules</p>
        <p class="mt-1 text-sm text-mist-700 dark:text-park-300">
          Permit for camping. No campfires. Pack water in. Stinger awareness Nov–May. Stay on tracks. Reef etiquette always.
        </p>
      </div>
    </aside>

    <WeatherWidget class="mt-8" />

    <section id="boat-access" class="mt-14 scroll-mt-28">
      <p class="section-label">Start here</p>
      <h2 class="mt-2 text-2xl font-bold sm:text-3xl">Boat access decision hierarchy</h2>
      <p class="mt-3 max-w-2xl text-mist-700 dark:text-park-200">
        Almost every good Whitsunday trip succeeds or fails on logistics — not on another filter pack. Master access, weather buffers and marine realism before you optimise for photos.
      </p>
      <ol class="mt-8 grid gap-4 sm:grid-cols-2">
        {
          accessSteps.map((step) => (
            <li class="card relative p-5 pl-14">
              <span
                class="absolute left-4 top-5 flex h-8 w-8 items-center justify-center rounded-full bg-park-600 text-sm font-bold text-white"
                aria-hidden="true"
              >
                {step.n}
              </span>
              <h3 class="font-bold text-park-900 dark:text-park-50">{step.title}</h3>
              <p class="mt-2 text-sm text-mist-700 dark:text-park-300">{step.detail}</p>
            </li>
          ))
        }
      </ol>
      <div class="mt-6 flex flex-wrap gap-3">
        <a href="/park/boat-access-airlie/" class="btn-primary !text-sm">Full boat-access guide</a>
        <a href="/visit/" class="btn-secondary !text-sm">Plan your visit</a>
        <a href="/itineraries/whitehaven-hill-inlet-day/" class="btn-secondary !text-sm">Classic day itinerary</a>
      </div>
    </section>

    <section class="mt-16">
      <p class="section-label">Pick your path</p>
      <h2 class="mt-2 text-2xl font-bold sm:text-3xl">What do you actually want?</h2>
      <div class="mt-8 grid gap-4 sm:grid-cols-2">
        {
          decisionTree.map((item) => (
            <a href={item.href} class="card group p-5 transition hover:border-park-400 hover:shadow-md dark:hover:border-park-500">
              <p class="text-xs font-bold uppercase tracking-[0.14em] text-park-600 dark:text-park-300">{item.label}</p>
              <h3 class="mt-1 text-lg font-bold text-park-900 group-hover:text-park-700 dark:text-park-50 dark:group-hover:text-glow">
                {item.title}
              </h3>
              <p class="mt-1 text-xs font-semibold text-mist-700 dark:text-park-400">{item.meta}</p>
              <p class="mt-2 text-sm text-mist-700 dark:text-park-300">{item.blurb}</p>
            </a>
          ))
        }
      </div>
    </section>

    <section class="mt-16">
      <div class="flex flex-wrap items-end justify-between gap-4">
        <div>
          <p class="section-label">Essential experiences</p>
          <h2 class="mt-2 text-2xl font-bold sm:text-3xl">Icon beach, lookout & reef</h2>
        </div>
        <a href="/trails/" class="text-sm font-semibold text-park-700 underline-offset-2 hover:underline dark:text-park-300">
          All walks & activities →
        </a>
      </div>
      <div class="mt-8 grid gap-6 sm:grid-cols-3">
        {featuredTrails.map((trail) => <TrailCard trail={trail} />)}
      </div>
      <figure class="mt-10 overflow-hidden rounded-2xl border border-mist-200 dark:border-park-700">
        <img
          src={siteImages.hillInlet.src.src}
          alt={siteImages.hillInlet.alt}
          class="h-56 w-full object-cover sm:h-72"
          loading="lazy"
          width={siteImages.hillInlet.src.width}
          height={siteImages.hillInlet.src.height}
        />
        <figcaption class="bg-white px-4 py-3 text-sm text-mist-700 dark:bg-park-900 dark:text-park-300">
          {siteImages.hillInlet.caption} — tide-dependent; verify conditions officially.
        </figcaption>
      </figure>
    </section>

    <section class="mt-16 rounded-2xl border border-warn-200 bg-warn-50/90 p-6 dark:border-park-600 dark:bg-park-900/60 sm:p-8">
      <p class="section-label !text-warn-800 dark:!text-glow">Marine & tropical realism</p>
      <h2 class="mt-2 text-2xl font-bold text-park-900 dark:text-park-50">Do not get this wrong</h2>
      <ul class="mt-4 space-y-2 text-sm text-park-900 dark:text-park-100">
        <li class="flex gap-2"><span aria-hidden="true">·</span> Wind and swell cancel boats — build a buffer day if Whitehaven is non-negotiable.</li>
        <li class="flex gap-2"><span aria-hidden="true">·</span> Stinger season is typically November–May — full-body suits or avoid swimming.</li>
        <li class="flex gap-2"><span aria-hidden="true">·</span> Hill Inlet swirl photography is tide-dependent — check BOM tides, not only Instagram.</li>
        <li class="flex gap-2"><span aria-hidden="true">·</span> Camping needs a QPWS permit, displayed tag, packed water and stove cooking (no campfires).</li>
        <li class="flex gap-2"><span aria-hidden="true">·</span> Stay on marked tracks; no coral standing; follow GBRMPA zoning if you skipper yourself.</li>
        <li class="flex gap-2"><span aria-hidden="true">·</span> Respect Ngaro cultural sites — no restricted photography or off-track wandering.</li>
      </ul>
      <div class="mt-6 flex flex-wrap gap-3">
        <a href="/park/marine-safety-seasons/" class="btn-primary !text-sm">Safety & seasons</a>
        <a href="/visit/" class="btn-secondary !text-sm">Plan your visit</a>
      </div>
    </section>

    <section class="mt-16">
      <div class="flex flex-wrap items-end justify-between gap-4">
        <div>
          <p class="section-label">Printable plans</p>
          <h2 class="mt-2 text-2xl font-bold sm:text-3xl">Itineraries that respect boats & tides</h2>
        </div>
        <a href="/itineraries/" class="text-sm font-semibold text-park-700 underline-offset-2 hover:underline dark:text-park-300">
          All itineraries →
        </a>
      </div>
      <div class="mt-8 grid gap-4 sm:grid-cols-3">
        {
          featuredItineraries.map((it) => (
            <a href={`/itineraries/${it.slug}/`} class="card p-5 transition hover:border-park-400 dark:hover:border-park-500">
              <p class="text-xs font-bold uppercase tracking-[0.12em] text-park-600 dark:text-park-300">{it.duration}</p>
              <h3 class="mt-2 font-bold text-park-900 dark:text-park-50">{it.name}</h3>
              <p class="mt-2 text-sm text-mist-700 dark:text-park-300">{it.summary}</p>
            </a>
          ))
        }
      </div>
    </section>

    <section class="mt-16">
      <LeadCapture />
    </section>

    <AdSense slot="home-mid" class="mt-12" />

    <section class="mt-16">
      <MonetisationPanel
        primaryStay="airlieBeach"
        title="Stays, tours & gear"
        description="Airlie Beach beds, Whitehaven day tours and tropical boat kit — camping permits and QPWS fees stay on official channels only."
      />
    </section>

    <section class="mt-16">
      <OfficialResources />
    </section>

    <section class="mt-16 text-center">
      <p class="section-label">Sister parks</p>
      <h2 class="mt-2 text-xl font-bold sm:text-2xl">More Farming Domains park guides</h2>
      <p class="mx-auto mt-2 max-w-xl text-sm text-mist-700 dark:text-park-300">
        Pair a Whitsunday island trip with Springbrook waterfalls, Port Campbell coast, Blue Mountains escarpment, Cradle alpine days or Uluru cultural logistics.
      </p>
      <div class="mt-6 flex flex-wrap justify-center gap-2">
        <a class="btn-secondary !text-sm" href="https://springbrooknationalpark.com.au/" target="_blank" rel="noopener noreferrer">Springbrook</a>
        <a class="btn-secondary !text-sm" href="https://www.portcampbellnationalpark.com.au/" target="_blank" rel="noopener noreferrer">Port Campbell</a>
        <a class="btn-secondary !text-sm" href="https://www.bluemountainsnationalpark.com.au/" target="_blank" rel="noopener noreferrer">Blue Mountains</a>
        <a class="btn-secondary !text-sm" href="https://www.cradlemountainnationalpark.com.au/" target="_blank" rel="noopener noreferrer">Cradle Mountain</a>
        <a class="btn-secondary !text-sm" href="https://www.whitsundayislandsnationalpark.com.au/" target="_blank" rel="noopener noreferrer">Whitsunday Islands</a>
      </div>
    </section>
  </div>
</Layout>
