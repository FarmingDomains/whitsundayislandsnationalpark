---
import Layout from '../../layouts/Layout.astro';
import OfficialResources from '../../components/OfficialResources.astro';
import { areas } from '../../data/areas';
import { official } from '../../data/seo';
---

<Layout
  title="Park overview"
  fullTitle="Whitsunday Islands National Park Overview · Areas & Gateways"
  description="Whitsunday Islands National Park areas: Whitehaven & Hill Inlet, boat access from Airlie Beach, camping beaches, snorkel reefs, Ngaro culture and marine safety — with Queensland Parks links."
  breadcrumbs={[
    { name: 'Home', href: '/' },
    { name: 'Park' },
  ]}
>
  <div class="page-container py-10 sm:py-14">
    <p class="section-label">Know the park</p>
    <h1 class="mt-2 text-3xl font-bold sm:text-4xl">Park overview & areas</h1>
    <p class="mt-4 max-w-3xl text-mist-700 dark:text-park-200/90">
      Whitsunday Islands National Park protects continental islands about 25 km east of Airlie Beach within the Great Barrier Reef World Heritage Area
      (park area on the order of ~170 km² — confirm current figures officially). The islands are boat-access only for visitors.
      Ngaro Traditional Owners hold ongoing connection to land and Sea Country. Use this hub to pick a focus, then verify conditions on the{' '}
      <a class="font-semibold text-park-700 underline-offset-2 hover:underline dark:text-park-300" href={official.park} target="_blank" rel="noopener noreferrer">official park site</a>.
    </p>
    <p class="mt-3 max-w-3xl text-sm text-mist-700 dark:text-park-300">
      <strong class="text-park-900 dark:text-park-100">Recommended order:</strong> choose boat path (day tour / camping transfer / private) →
      base in Airlie Beach → Whitehaven + Hill Inlet when conditions allow → camping only with QPWS permit and water plan → snorkel only when seas and stinger risk allow.
    </p>
    <p class="mt-3 max-w-3xl text-sm text-mist-700 dark:text-park-300">
      We acknowledge Ngaro Traditional Owners and their continuing connection to Country. This guide does not retell restricted sacred stories.
    </p>

    <div class="mt-10 grid gap-4 md:grid-cols-2">
      {
        areas.map((area) => (
          <a href={`/park/${area.slug}/`} class="card block p-5 transition hover:border-park-400 hover:shadow-md">
            <h2 class="text-xl font-bold text-park-900 dark:text-park-50">{area.name}</h2>
            <p class="mt-2 text-sm text-mist-700 dark:text-park-300 line-clamp-3">{area.summary}</p>
            <p class="mt-3 text-xs font-medium text-park-600 dark:text-park-300">{area.driveNote}</p>
            <p class="mt-3 text-sm font-semibold text-park-700 dark:text-park-200">Area guide →</p>
          </a>
        ))
      }
    </div>

    <div class="mt-12">
      <OfficialResources />
    </div>
  </div>
</Layout>
