---
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { blogPosts } from '../../data/blog';

const crumbs = [
  { name: 'Home', href: '/' },
  { name: 'Articles' },
];
---

<Layout
  title="Articles"
  fullTitle="Whitsunday Articles · Whitehaven, Camping & Boat Access Tips"
  description="Whitsunday Islands National Park tips: Whitehaven day trips, camping permits, boat-access decisions, stinger season packing, Hill Inlet tides and Ngaro cultural respect."
  breadcrumbs={crumbs}
>
  <div class="page-container py-8 sm:py-12">
    <Breadcrumbs items={crumbs} />
    <h1 class="mt-4 text-3xl font-bold sm:text-4xl">Articles</h1>
    <p class="mt-3 max-w-3xl text-mist-700 dark:text-park-200">
      Practical planning notes for Whitsunday Islands visits. Always verify track conditions with Queensland Parks (QPWS).
    </p>
    <div class="mt-8 grid gap-4">
      {
        blogPosts.map((post) => (
          <a href={`/articles/${post.slug}/`} class="card block p-5 transition hover:border-park-400">
            <p class="text-xs font-semibold text-park-600 dark:text-park-300">{post.date}</p>
            <h2 class="mt-1 text-lg font-bold text-park-900 dark:text-park-50">{post.title}</h2>
            <p class="mt-2 text-sm text-mist-700 dark:text-park-300">{post.description}</p>
            <p class="mt-3 text-xs font-semibold text-park-600 dark:text-park-300">Read →</p>
          </a>
        ))
      }
    </div>
  </div>
</Layout>
