---
import Layout from '../layouts/Layout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { official } from '../data/seo';
import { contentMeta } from '../data/contentMeta';

const crumbs = [
  { name: 'Home', href: '/' },
  { name: 'Contact' },
];

const accessKey = import.meta.env.PUBLIC_SPLITFORMS_ACCESS_KEY?.trim() || '';
const formReady = accessKey.length > 0;
---

<Layout
  title="Contact"
  fullTitle="Contact · Whitsunday Islands National Park Guide"
  description="Contact the unofficial Whitsunday Islands National Park guide. Not for park emergencies — use 000 and Queensland Parks (QPWS) for official help."
  breadcrumbs={crumbs}
>
  <div class="page-container py-8 sm:py-12">
    <Breadcrumbs items={crumbs} />
    <h1 class="mt-4 text-3xl font-bold sm:text-4xl">Contact</h1>
    <p class="mt-2 text-sm text-mist-700 dark:text-park-400">Page updated {contentMeta.siteReviewed}</p>
    <p class="mt-3 max-w-2xl text-mist-700 dark:text-park-200">
      Website questions, corrections and partnership notes only. For park emergencies call <strong>000</strong>.
      For official park information use{' '}
      <a class="font-semibold underline-offset-2 hover:underline" href={official.park} target="_blank" rel="noopener noreferrer">Queensland Parks (QPWS) — Whitsunday Islands</a>.
    </p>

    <div class="mt-8 max-w-2xl rounded-2xl border border-warn-200 bg-warn-50 p-5 dark:border-amber-800/50 dark:bg-amber-950/40">
      <h2 class="text-lg font-bold text-warn-800 dark:text-amber-100">Not for park emergencies</h2>
      <p class="mt-2 text-sm text-warn-800/90 dark:text-amber-100/90">
        This channel is only for feedback about this unofficial website (Farming Domains / Ian Piggott). Official fees,
        track status and safety belong on Queensland Parks (QPWS) channels.
      </p>
    </div>

    <div class="mt-8 max-w-xl">
      <div
        id="contact-thanks"
        class="mt-2 hidden rounded-2xl border border-park-300 bg-park-50 p-6 dark:border-park-600 dark:bg-park-900/60"
        role="status"
        hidden
      >
        <p class="text-lg font-bold">Message sent</p>
        <p class="mt-2 text-sm text-mist-700 dark:text-park-200/90">Thanks — your message has been received.</p>
        <a href="/" class="btn-primary mt-4">Back to home</a>
      </div>

      <p
        id="contact-error"
        class="mt-2 hidden rounded-2xl border border-rose-300 bg-rose-50 p-4 text-sm text-rose-900 dark:border-rose-800 dark:bg-rose-950/40 dark:text-rose-100"
        role="alert"
        hidden
      ></p>

      {
        formReady ? (
          <form
            id="contact-form-slot"
            class="card space-y-4 p-5 sm:p-6"
            method="POST"
            action="https://splitforms.com/api/submit"
          >
            <input type="hidden" name="access_key" value={accessKey} />
            <input type="hidden" name="subject" value="Whitsunday Islands guide — website contact" />
            <input type="hidden" name="from_name" value="Whitsunday Islands National Park guide" />
            {/* Splitforms honeypot — leave empty; bots often fill it */}
            <input type="checkbox" name="botcheck" class="hidden" tabindex="-1" autocomplete="off" aria-hidden="true" />
            <div>
              <label class="contact-label" for="contact-name">Name</label>
              <input class="contact-input" id="contact-name" name="name" type="text" required autocomplete="name" placeholder="Your name" />
            </div>
            <div>
              <label class="contact-label" for="contact-email">Email</label>
              <input class="contact-input" id="contact-email" name="email" type="email" required autocomplete="email" placeholder="Your email" />
            </div>
            <div>
              <label class="contact-label" for="contact-message">Message</label>
              <textarea class="contact-input min-h-[140px]" id="contact-message" name="message" required rows="5" placeholder="Message" />
            </div>
            <button type="submit" class="btn-primary">Send message</button>
            <p class="affiliate-note">
              Submissions via Splitforms. See <a href="/privacy/" class="underline-offset-2 hover:underline">Privacy</a>.
            </p>
          </form>
        ) : (
          <div class="card p-5 text-sm text-mist-700 dark:text-park-300">
            Contact form activates when <code>PUBLIC_SPLITFORMS_ACCESS_KEY</code> is set in <code>site/.env</code> at
            build time. Rebuild and re-upload <code>dist/</code>, or reach the publisher via{' '}
            <a href="https://ianpiggott.com" target="_blank" rel="noopener noreferrer">ianpiggott.com</a>.
          </div>
        )
      }
    </div>
  </div>
</Layout>

<script define:vars={{ formReady }}>
  if (formReady) {
    const form = document.getElementById('contact-form-slot');
    const thanks = document.getElementById('contact-thanks');
    const err = document.getElementById('contact-error');
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!form || !(form instanceof HTMLFormElement)) return;
      err?.classList.add('hidden');
      err?.setAttribute('hidden', '');
      try {
        const res = await fetch('https://splitforms.com/api/submit', {
          method: 'POST',
          body: new FormData(form),
        });
        if (!res.ok) throw new Error('fail');
        form.classList.add('hidden');
        thanks?.classList.remove('hidden');
        thanks?.removeAttribute('hidden');
      } catch {
        if (err) {
          err.textContent = 'Could not send right now. Please try again later, or use ianpiggott.com.';
          err.classList.remove('hidden');
          err.removeAttribute('hidden');
        }
      }
    });
  }
</script>
