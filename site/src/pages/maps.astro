---
import Layout from '../layouts/Layout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import MapEmbed from '../components/MapEmbed.astro';
import LeadCapture from '../components/LeadCapture.astro';
import OfficialResources from '../components/OfficialResources.astro';
import { official } from '../data/seo';

const crumbs = [
  { name: 'Home', href: '/' },
  { name: 'Maps & resources' },
];
---

<Layout
  title="Maps & resources"
  fullTitle="Whitsunday Maps, Downloads & Resources"
  description="Whitsunday Islands maps: Whitehaven Beach, Hill Inlet, Airlie Beach and Shute Harbour. Free Practical Planner download and official Queensland Parks resources."
  breadcrumbs={crumbs}
>
  <div class="page-container py-8 sm:py-12">
    <Breadcrumbs items={crumbs} />
    <h1 class="mt-4 text-3xl font-bold sm:text-4xl">Maps & resources</h1>
    <p class="mt-3 max-w-3xl text-mist-700 dark:text-park-200">
      Orientation only — then verify track status, camping availability and marine rules on{' '}
      <a class="font-semibold text-park-700 underline-offset-2 hover:underline dark:text-park-300" href={official.park} target="_blank" rel="noopener noreferrer">Queensland Parks — Whitsunday Islands</a>
      {' '}and{' '}
      <a class="font-semibold text-park-700 underline-offset-2 hover:underline dark:text-park-300" href={official.gbrmpaWhitsundays} target="_blank" rel="noopener noreferrer">GBRMPA Whitsundays</a>.
    </p>

    <div class="mt-8 grid gap-8">
      <MapEmbed query="Whitehaven Beach Whitsunday Island Queensland" title="Map — Whitehaven Beach" zoom={12} />
      <MapEmbed query="Hill Inlet Lookout Whitsunday Island" title="Map — Hill Inlet lookout" zoom={13} />
      <MapEmbed query="Airlie Beach Queensland" title="Map — Airlie Beach" zoom={13} />
      <MapEmbed query="Shute Harbour Queensland" title="Map — Shute Harbour" zoom={13} />
    </div>

    <div class="mt-10">
      <LeadCapture
        heading="Free Whitsunday Islands Practical Planner"
        blurb="Printable boat-access decision tree, Whitehaven + Hill Inlet tide notes, camping vs day-trip comparison, stinger packing and official links."
        downloadPath="/downloads/whitsunday-practical-planner.html"
      />
      <p class="mt-4 text-sm text-mist-700 dark:text-park-300">
        Direct download (no email required):{' '}
        <a class="font-semibold text-park-700 underline-offset-2 hover:underline dark:text-park-300" href="/downloads/whitsunday-practical-planner.html">
          whitsunday-practical-planner.html
        </a>
      </p>
    </div>

    <div class="mt-10">
      <OfficialResources />
    </div>
  </div>
</Layout>
