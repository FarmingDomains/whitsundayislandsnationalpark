---
import Layout from '../../layouts/Layout.astro';
import TrailCard from '../../components/TrailCard.astro';
import OfficialResources from '../../components/OfficialResources.astro';
import ContentImage from '../../components/ContentImage.astro';
import { trails } from '../../data/trails';
import { official } from '../../data/seo';
import { siteImages } from '../../data/pageImages';
---

<Layout
  title="Walks & lookouts"
  fullTitle="Whitsunday Islands Walks · Hill Inlet, Whitehaven & Island Tracks"
  description="Whitsunday Islands walks and activities: Hill Inlet lookout, Whitehaven Beach, short island tracks, camping beach links, Ngaro Cultural Site and Ngaro Track overview. Verify status with Queensland Parks."
  breadcrumbs={[
    { name: 'Home', href: '/' },
    { name: 'Walks' },
  ]}
>
  <div class="page-container py-10 sm:py-14">
    <p class="section-label">Walk hierarchy</p>
    <h1 class="mt-2 text-3xl font-bold sm:text-4xl">Walks, beaches & lookouts</h1>
    <p class="mt-4 max-w-3xl text-mist-700 dark:text-park-200/90">
      Start with boat logistics, then the icon pair <strong>Whitehaven Beach + Hill Inlet lookout</strong> (~1.3 km return, moderate, ~40 min walking)
      when your tour or transfer includes both. Short island tracks and camping-beach links add depth; multi-day Ngaro Track is advanced and limited.
      Distances, grades and times below are planning ranges — always confirm on{' '}
      <a class="font-semibold text-park-700 underline-offset-2 hover:underline dark:text-park-300" href={official.park} target="_blank" rel="noopener noreferrer">Queensland Parks</a>
      {' '}and the{' '}
      <a class="font-semibold text-park-700 underline-offset-2 hover:underline dark:text-park-300" href={official.hillInlet} target="_blank" rel="noopener noreferrer">Hill Inlet lookout track</a> page.
    </p>

    <div class="mt-8">
      <ContentImage
        src={siteImages.hillInlet.src}
        alt={siteImages.hillInlet.alt}
        caption={siteImages.hillInlet.caption}
        imgClass="max-h-64 w-full object-cover"
      />
    </div>

    <div class="mt-10 grid gap-4 md:grid-cols-2">
      {trails.map((t) => <TrailCard trail={t} />)}
    </div>

    <div class="mt-12">
      <OfficialResources />
    </div>
  </div>
</Layout>
